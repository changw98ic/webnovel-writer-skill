{
  "name": "@webnovel-skill/dashboard",
  "version": "1.0.0",
  "description": "可视化面板 - Fastify 后端",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run packages/dashboard"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "@webnovel-skill/core": "workspace:*",
    "@webnovel-skill/data": "workspace:*",
    "fastify": "^4.29.1"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
