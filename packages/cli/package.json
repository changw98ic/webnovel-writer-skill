{
  "name": "@changw98ic/cli",
  "version": "1.0.1",
  "description": "命令行工具 - webnovel 命令",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "webnovel": "dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "test": "vitest run packages/cli",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "webnovel",
    "writing",
    "ai",
    "cli",
    "command-line",
    "novel"
  ],
  "author": "",
  "license": "GPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/changw98ic/webnovel-writer-skill.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/changw98ic/webnovel-writer-skill/issues"
  },
  "homepage": "https://github.com/changw98ic/webnovel-writer-skill#readme",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@changw98ic/core": "workspace:*",
    "@changw98ic/data": "workspace:*",
    "@changw98ic/adapters": "workspace:*",
    "@changw98ic/dashboard": "workspace:*",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "chalk": "^5.3.0",
    "enquirer": "^2.4.0",
    "conf": "^10.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
