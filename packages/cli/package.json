{
  "name": "@webnovel-skill/cli",
  "version": "1.0.0",
  "description": "命令行工具 - webnovel 命令",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "webnovel": "./dist/index.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "test": "vitest run packages/cli"
  },
  "dependencies": {
    "@webnovel-skill/core": "workspace:*",
    "@webnovel-skill/data": "workspace:*",
    "@webnovel-skill/adapters": "workspace:*",
    "@webnovel-skill/dashboard": "workspace:*",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "chalk": "^5.3.0",
    "enquirer": "^2.4.0",
    "conf": "^10.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
