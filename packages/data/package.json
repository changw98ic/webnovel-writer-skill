{
  "name": "@webnovel-skill/data",
  "version": "1.0.0",
  "description": "数据层 - 状态管理、实体索引、RAG 检索",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./state": {
      "import": "./dist/state/index.js",
      "types": "./dist/state/index.d.ts"
    },
    "./index": {
      "import": "./dist/index-manager/index.js",
      "types": "./dist/index-manager/index.d.ts"
    },
    "./rag": {
      "import": "./dist/rag/index.js",
      "types": "./dist/rag/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "test": "vitest run packages/data"
  },
  "dependencies": {
    "@webnovel-skill/core": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "proper-lockfile": "^4.1.0",
    "undici": "^6.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/proper-lockfile": "^4.1.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
